generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String     @id @default(uuid())
  clerkId                 String     @unique
  email                   String     @unique
  name                    String?
  stripeCustomerId        String?    @unique
  currentTier             String?    // launch | pro | closer | null
  billingCycle            String?    // monthly | annual
  subscriptionRunsRemaining Int      @default(0)
  subscriptionRunsTotal   Int        @default(0)
  priorityProcessing      Boolean    @default(false)
  stripeSubscriptionId    String?
  subscriptionStatus      String     @default("none") // active | canceled | past_due | none
  currentPeriodEnd        DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  runPacks                RunPack[]
  runLogs                 RunLog[]
  runRequests             RunRequest[]
  batchJobs               BatchJob[]
  knowledgeDocs           KnowledgeDocument[]
  debriefs                RunDebrief[]
  practiceSessions        PracticeSession[]
  targets                 Target[]
  userProfile             UserProfile?

  // Team relationships
  ownedTeams              Team[]       @relation("TeamOwner")
  teamMemberships         TeamMember[]
}

model Team {
  id                      String     @id @default(uuid())
  name                    String
  slug                    String     @unique
  description             String?    @db.Text

  // Billing (team owns its own Stripe customer)
  stripeCustomerId        String?    @unique
  currentTier             String?    // launch | pro | closer
  billingCycle            String?    // monthly | annual
  subscriptionRunsRemaining Int      @default(0)
  subscriptionRunsTotal   Int        @default(0)
  stripeSubscriptionId    String?
  subscriptionStatus      String     @default("none")
  currentPeriodEnd        DateTime?
  maxSeats                Int        @default(5)  // seat limit per plan

  // Ownership
  ownerId                 String
  owner                   User       @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Relations
  members                 TeamMember[]
  runRequests             RunRequest[]
  batchJobs               BatchJob[]
  knowledgeDocs           KnowledgeDocument[]
  runPacks                RunPack[]

  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
}

model TeamMember {
  id              String    @id @default(uuid())
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId          String?   // null if invite is pending (user hasn't signed up yet)
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String    @default("member")  // owner | admin | member
  inviteEmail     String    // email the invite was sent to
  inviteStatus    String    @default("pending")  // pending | accepted | declined
  invitedBy       String?   // userId of inviter
  joinedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([teamId, userId])
  @@unique([teamId, inviteEmail])
}

model RunPack {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  runsRemaining Int
  runsTotal     Int
  purchasedAt   DateTime @default(now())
  expiresAt     DateTime
  type          String   // pack_5 | pack_10 | pack_20 | interview_sprint
  allowedTools  String[] // empty array = all accessible tools; ["interview_outreach", "interview_prep"] for sprint
  stripePaymentId String?
}

model RunLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?  // track which team the run was for (if any)
  toolName  String
  createdAt DateTime @default(now())
  source    String   // subscription | pack | sprint
  status    String   @default("completed") // completed | failed | in_progress
  priority  Boolean  @default(false)
}

model BatchJob {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status          String   @default("submitted") // submitted | researching | synthesizing | ready | delivered | failed
  batchType       String   @default("territory_mapping") // territory_mapping | multi_threading | competitive_sweep
  toolName        String   @default("prospect_prep")
  accounts        Json     @default("[]") // Array of account input objects
  sharedContext   Json?    // Shared context across all accounts
  synthesisData   Json?    // Comparative analysis output
  batchAssets     Json     @default("[]") // Batch-level deliverables
  steps           Json     @default("[]") // Batch-level orchestration steps
  priority        Boolean  @default(false)
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  deliveredAt     DateTime?
  childRequests   RunRequest[]
}

model RunRequest {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  toolName        String   // interview_prep | interview_outreach | prospect_prep | prospect_outreach | deal_audit | champion_builder
  status          String   @default("submitted") // submitted | researching | generating | ready | delivered | failed
  priority        Boolean  @default(false)

  // Batch relationship
  batchJobId      String?
  batchJob        BatchJob? @relation(fields: [batchJobId], references: [id], onDelete: SetNull)
  batchIndex      Int?     // Position in batch (0-indexed)

  // Target graph (links all activity for one company/person pair)
  targetId        String?
  target          Target?  @relation(fields: [targetId], references: [id])

  // Customer inputs
  targetName      String   // Name of person or account
  targetCompany   String   // Company name
  targetRole      String?  // Role/title (for interview tools)
  jobDescription  String?  @db.Text // Full JD text
  linkedinUrl     String?  // LinkedIn profile URL
  linkedinText    String?  @db.Text // Pasted LinkedIn summary + experience
  additionalNotes String?  @db.Text // Any extra context from customer
  targetCompanyUrl String?  // Target company website URL
  caseStudies     String?  @db.Text // Customer stories & case studies for social proof in outreach
  interviewInstructions String? @db.Text // Specific interview prep instructions or assignment the candidate was given

  // Meeting type (controls which call prep docs are generated)
  // interview_prep: "mock_pitch" | "hiring_manager"
  // prospect_prep: "discovery" | "follow_up" | "pitch" | "closing"
  meetingType     String?

  // Engagement context
  engagementType           String   @default("cold_outreach")
  meetingDate              DateTime?
  priorInteractions        String?  @db.Text

  // Execution tracking
  currentStep     String?  // Current step ID (e.g., "competitive_research", "market_intel", "generating_assets")
  steps           Json     @default("[]") // Array of { id, label, status, startedAt, completedAt }
  assets          Json     @default("[]") // Array of { id, label, format, url, size? }
  researchData    Json?    // Cached research output from L1-L3 (feeds into asset generation)
  enrichmentData  Json?    // Apollo.io enrichment data (contact + company intelligence)
  errorMessage    String?  @db.Text // Error details if failed

  // Pre-execution clarification (v2.5)
  clarificationQuestions Json?    // Generated questions from executor
  clarificationAnswers  Json?    // User's answers
  clarificationSentAt   DateTime? // When clarification email was sent

  // Delivery
  deliveryUrl     String?  // Google Drive folder URL or download link
  deliveryNotes   String?  @db.Text // Notes about what was delivered
  adminNotes      String?  @db.Text // Internal notes (not visible to customer)

  // Post-run debrief
  debriefs        RunDebrief[]

  // Interview panel (1:1 for interview_prep runs with multi-interviewer context)
  interviewPanel  InterviewPanel?

  // Practice sessions spawned from this blitz
  practiceSessions PracticeSession[]

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  startedAt       DateTime? // When execution begins
  completedAt     DateTime? // When assets are ready
  deliveredAt     DateTime? // When customer is notified
}

model UserProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company context
  companyName           String?  @map("company_name")
  companyProduct        String?  @map("company_product") @db.Text
  companyDescription    String?  @map("company_description") @db.Text
  companyDifferentiators String? @map("company_differentiators") @db.Text
  companyCompetitors    String?  @map("company_competitors") @db.Text
  companyTargetMarket   String?  @map("company_target_market") @db.Text
  companyUrl            String?  @map("company_url")

  // Customer's own LinkedIn
  linkedinAbout         String?  @map("linkedin_about") @db.Text
  linkedinExperience    String?  @map("linkedin_experience") @db.Text
  linkedinEducation     String?  @map("linkedin_education") @db.Text

  // Selling methodology & style
  sellingStyle          String?  @default("MEDDPICC") @map("selling_style")
  sellingPhilosophy     String?  @map("selling_philosophy") @db.Text  // How they think about selling (discovery-led, challenger, consultative)
  sellerArchetype       String?  @map("seller_archetype")             // e.g., "enterprise_closer", "consultative_hunter", "expansion_farmer"

  // Career & interview context (used by interview tools)
  careerNarrative       String?  @map("career_narrative") @db.Text    // 2-3 sentence career arc summary
  targetRoleTypes       Json     @default("[]") @map("target_role_types")  // ["enterprise_ae", "strategic_ae", "team_lead"]
  keyStrengths          Json     @default("[]") @map("key_strengths")      // ["discovery", "multithreading", "executive_presence"]
  interviewHistory      Json     @default("[]") @map("interview_history")  // [{company, role, round, outcome, date, notes}]

  // Territory & ICP context (used by prospecting tools)
  icpDefinitions        Json     @default("[]") @map("icp_definitions")    // [{industry, companySize, buyerPersona, commonPains}]
  territoryFocus        String?  @map("territory_focus") @db.Text          // Geographic/vertical/segment focus
  currentQuotaContext   String?  @map("current_quota_context") @db.Text    // Where they are vs. quota, pipeline health

  // Sales assets (JSONB)
  // dealStories schema: [{company, dealSize, timeline, origin, beforeState, negativeConsequences,
  //   requiredCapabilities, pbos, howWon, champion, economicBuyer, competition,
  //   cotmMapping: {beforeState, negConsequences, reqCapabilities, pbos},
  //   meddpiccMapping: {metrics, econ_buyer, decision_criteria, decision_process, paper_process, identified_pain, champion, competition},
  //   starMapping: {situation, task, action, result},
  //   verticals: [], dealSize: "", sellCycle: ""}]
  dealStories           Json     @default("[]") @map("deal_stories")
  caseStudies           Json     @default("[]") @map("case_studies")       // [{customerName, challenge, solution, result, quote, industry}]
  valueProps            Json     @default("[]") @map("value_props")

  // Writing & communication style
  writingStyle          String?  @map("writing_style") @db.Text           // Description of their writing voice
  bannedPhrases         Json     @default("[]") @map("banned_phrases")    // Phrases to never use in their output
  signaturePatterns     Json     @default("[]") @map("signature_patterns") // Phrases/patterns they like to use

  // Lifecycle & onboarding
  lifecycleStage        String?  @default("selling") @map("lifecycle_stage")  // "interviewing" | "ramping" | "selling" | "managing"
  onboardingDepth       Int      @default(0) @map("onboarding_depth")         // 0-4: none, essentials, post-first-blitz, post-third-blitz, rich
  preferredTone         String?  @default("professional") @map("preferred_tone")
  onboardingCompleted   Boolean  @default(false) @map("onboarding_completed") // Kept for backward compat

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_profile")
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  category  String   @default("custom") // product_docs | competitive_intel | deal_stories | icp_definitions | methodology | objection_handling | custom
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI Practice Mode — real-time roleplay against HeyGen streaming avatar.
// Persona generated from account research, scored against CotM framework.
model PracticeSession {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Target graph (links to persistent Target entity)
  targetId          String?
  target            Target?  @relation(fields: [targetId], references: [id])

  // Blitz that spawned this session (if any)
  runRequestId      String?
  runRequest        RunRequest? @relation(fields: [runRequestId], references: [id])

  // Target context
  targetCompany     String   // Company the persona represents
  targetRole        String?  // Persona's role/title
  personaName       String?  // Generated persona name
  personaConfig     Json?    // Full persona definition (personality, objections, priorities, style)

  // Panel mode (multi-interviewer simulation)
  isPanelMode       Boolean  @default(false)
  panelMemberStates Json?    // { currentSpeakerIndex, turnCounts: { [memberId]: number }, members: [...] }

  // Session continuity (learning across rounds)
  previousSessionId String?  // FK to prior session for same target (self-relation)
  previousSession   PracticeSession? @relation("SessionChain", fields: [previousSessionId], references: [id])
  nextSessions      PracticeSession[] @relation("SessionChain")
  focusAreas        Json?    // string[] from prior debrief synthesis (what to push harder on)
  sessionSequence   Int      @default(1) // 1st, 2nd, 3rd session for this target

  // Session data
  heygenSessionId   String?  // HeyGen streaming session ID
  avatarId          String?  // HeyGen avatar used
  voiceId           String?  // HeyGen voice used
  transcript        Json     @default("[]") // Array of { role: "user" | "persona", text, timestamp, speaker?, speakerTitle? }
  durationSeconds   Int?     // Total session length

  // Scoring
  cotmScore         Json?    // { overall, beforeState, negativeConsequences, requiredCapabilities, pbos, howWeDoIt }
  feedback          String?  @db.Text // AI-generated coaching feedback
  outcome           String?  // strong | developing | needs_work

  // User self-debrief (notes after reviewing score)
  userNotes         String?  @db.Text // User's own reflections, what to work on next

  // Status
  status            String   @default("created") // created | active | completed | failed
  errorMessage      String?  @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  completedAt       DateTime?
}

// Target — groups all activity (blitzes, practice sessions, debriefs) for one company/person pair.
// Accumulates intelligence across rounds, enabling the learning flywheel.
model Target {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  contactName     String?
  contactTitle    String?
  type            String   @default("prospect") // prospect | interview
  roundCount      Int      @default(0)
  currentRound    Int      @default(1)
  accumulatedIntel String? @db.Text // synthesized learnings across rounds, max 5K
  status          String   @default("active") // active | paused | closed | won | lost
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  runRequests      RunRequest[]
  practiceSessions PracticeSession[]

  @@unique([userId, companyName, contactName])
  @@index([userId])
}

// InterviewPanel — captures multi-interviewer composition per interview_prep run.
// One panel per RunRequest (1:1). Contains one or more InterviewPanelMembers.
model InterviewPanel {
  id           String   @id @default(uuid())
  runRequestId String   @unique
  runRequest   RunRequest @relation(fields: [runRequestId], references: [id], onDelete: Cascade)
  roundType    String   // phone_screen | panel | final | executive | mock_pitch
  roundNumber  Int      @default(1)
  assignment   String?  @db.Text // interview assignment/case study text
  createdAt    DateTime @default(now())

  members InterviewPanelMember[]
}

// InterviewPanelMember — one per interviewer on a panel.
// personalityVibe drives avatar selection in Practice Mode.
model InterviewPanelMember {
  id              String  @id @default(uuid())
  panelId         String
  panel           InterviewPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  name            String
  title           String?
  roleInMeeting   String  // hiring_manager | peer | executive_sponsor | technical_evaluator | cross_functional
  personalityVibe String? // analytical_skeptical | relationship_first | high_energy_challenger | warm_collaborative
  knownObjections String? @db.Text
  evaluationFocus String? @db.Text // what they specifically evaluate
  linkedinUrl     String?
  order           Int     @default(0) // display/switching order

  @@index([panelId])
}

// Post-run debrief — captures user feedback after a meeting/interview.
// Fed into subsequent runs targeting the same company for progressive context building.
model RunDebrief {
  id              String     @id @default(uuid())
  runRequestId    String
  runRequest      RunRequest @relation(fields: [runRequestId], references: [id], onDelete: Cascade)
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What happened
  content         String     @db.Text // Free-form debrief (what landed, what didn't, next steps, objections, intel)
  outcome         String?    // positive | neutral | negative | unknown
  nextSteps       String?    @db.Text // Specific next steps identified

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
